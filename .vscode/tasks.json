{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Copy Handlebars",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-Command",
				"Copy-Item -Path 'node_modules/handlebars/dist/handlebars.min.js' -Destination 'src/scripts/handlebars.min.js' -Force"
			],
			"problemMatcher": []
		},
		{
			"label": "Build SCSS",
			"type": "shell",
			"command": "npx",
			"args": [
				"sass",
				"src/styles:src/styles",
				"--no-source-map"
			],
			"dependsOn": "Copy Handlebars",
			"dependsOrder": "sequence",
			"group": "build"
		},
		{
			"label": "Build Lovelace",
			"type": "shell",
			"command": "node",
			"args": [
				"build-lovelace.mjs"
			],
			"dependsOn": "Build SCSS",
			"dependsOrder": "sequence",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Watch SCSS",
			"type": "shell",
			"command": "npx",
			"args": [
				"sass",
				"src/styles:src/styles",
				"--no-source-map",
				"--watch"
			],
			"dependsOn": "Copy Handlebars",
			"dependsOrder": "sequence",
			"isBackground": true,
			"group": "build"
		}
	]
}