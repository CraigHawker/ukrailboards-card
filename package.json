{
  "name": "board",
  "private": true,
  "description": "Home Assistant UK rail departure board custom card and demo build.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:css": "npx sass src/styles:src/styles --no-source-map",
    "build:demo": "node build-lovelace.mjs demo",
    "build:card": "node build-lovelace.mjs card",
    "build:js": "node build-lovelace.mjs all",
    "build": "npm run build:css && npm run build:js",
    "build:release": "npm run build:css && npm run build:card",
    "package:inspect": "npm run build:release && node src/scripts/package-release.mjs"
  },
  "dependencies": {
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "esbuild": "^0.25.2",
    "ttf2woff2": "^8.0.1"
  }
}
